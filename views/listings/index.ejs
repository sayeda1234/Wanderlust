<% layout('layout/boilerplate') %>
<style>
  .filter{
    margin-top: 1rem;
    opacity: 0.7;
    margin-right: 1.5rem;
    text-decoration: none;
  }
  .filter:hover{
    opacity: 1;
  }
  .filter p{
    font-size: 0.8rem;
  }
  #filters{
    align-items: center;
  }
  .tax-info{
    display: none;
  }
  .tag-toggle{
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.5rem;
    padding: 1rem;
    margin-left: 3rem;
    display: flex;
    align-items: center;
  }
</style>
<div id="filters" class="d-flex gap-4 mb-3">
    <a href="/listings/category/Trending" class="filter text-center">
    <i class="fa-solid fa-fire"></i>
    <p>Trending</p>
</a>
  <a href="/listings/category/Rooms" class="filter text-center">
    <i class="fa-solid fa-bed"></i>
    <p>Rooms</p>
  </a>
   <a href="/listings/category/Iconic ities" class="filter text-center">
    <i class="fa-solid fa-mountain-city"></i>
    <p>Iconic Cities</p>
   </a>
  <a href="/listings/category/Mountain" class="filter text-center">
   <i class="fa-solid fa-mountain"></i>
    <p>Mountain</p>
  </a>
   <a href="/listings/category/Castles" class="filter text-center">
   <i class="fa-brands fa-fort-awesome"></i>
    <p>Castles</p>
   </a>
 <a href="/listings/category/Arctic" class="filter text-center">
<i class="fa-solid fa-snowflake"></i>
    <p>Arctic</p>
 </a>
  <a href="/listings/category/Camping" class="filter text-center">
  <i class="fa-solid fa-campground"></i>
    <p>Camping</p>
  </a>
  <a href="/listings/category/Farms" class="filter text-center">
 <i class="fa-solid fa-cow"></i>
    <p>Farms</p>
  </a>
    <a href="/listings/category/Domes" class="filter text-center">
 <i class="fa-solid fa-igloo"></i>
    <p>Domes</p>
  </a>
    <a href="/listings/category/Boat" class="filter text-center">
 <i class="fa-solid fa-ship"></i>
    <p>Boat</p>
  </a>
  
<div class="tag-toggle">
  <div class="form-check-reverse form-switch">
  <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
  <label class="form-check-label" for="switchCheckDefault">Display Total after Taxes</label>
</div>
</div>
</div>


<div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4 mt-3">
  <% for (let listing of allListings) { %>

    <div class="col">
      <a href="/listings/<%=listing._id%>" class="listing-link text-decoration-none text-dark">
        <div class="card listing-card h-100">
          <img
            src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1625505826533-5c80aca7d157?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=60' %>"
            class="card-img-top"
            alt="listing image"
            style="height: 20rem; object-fit: cover;"
          />
          <div class="card-body">
            <h5 class="card-title"><b><%= listing.title %></b></h5>
            <p class="card-text">₹<%= listing.price %> /night <i class="tax-info"> +18% GST</i></p>
          
          </div>
        </div>
      </a>
    </div>

  <% } %>
</div>

<script>
  let taxSwitch=document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click",()=>{
    let taxinfo=document.getElementsByClassName("tax-info");
    for(info of taxinfo)
    {
      if(info.style.display !="inline")
      {
        info.style.display="inline";
      }else{
        info.style.display="none";
      }
    }
      
  
  })
</script>